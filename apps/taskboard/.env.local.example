# Cursor Dashboard → Integrations で発行したAPIキー
CURSOR_API_KEY="cursor_ここに自分のキー"

# 任意。未指定ならCursor側が利用可能モデルを選ぶ
SONTOKU_MODEL="auto"

# 任意。設定すると /api/state, /api/sontoku にヘッダ認証を要求する（LAN/Tailscale経由の第三者アクセス対策）
TASKBOARD_TOKEN=""

# Googleカレンダー連携（詳細: GOOGLE_CALENDAR.md）
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://127.0.0.1:8765/api/gcal/callback"
# GOOGLE_CALENDAR_ID="primary"
GCAL_REMINDERS_MINUTES="1440,180,90"
